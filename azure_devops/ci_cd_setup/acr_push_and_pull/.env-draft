# ============ Variables for which we can leave the default values ============

# Name of the variable group which we will create in DevOps Library
DEVOPS_VARIABLE_GROUP_NAME = 'ACR-SP-credentials'
# name of the image repository in ACR to which we will push our Docker image. It will be created if it doesn't exist
IMAGE_REPOSITORY_NAME = 'airflow'
# The tag which will be assigned to the Docker image pushed to the ACR.
IMAGE_TAG = '$(Build.BuildId)'




# ============ Variables for which we shouldn't be changing values. If we want to change them, then we might need to change other parts of code. ============

# name of the Agent pool which will be used for performing the CI/CD pipeline. That pool can be created using agent_pool_setup > setup.py script.
POOL_NAME = 'data_engineering_apps'
# Name of the resource group with our ACR
ACR_RG = 'data_engineering_apps_acr'
# Name of the ACR
ACR_NAME = 'dataEngineeringApps'




# ============ Variables for which we need to provide correct values. ============

# path to the Dockerfile and docker compose files relative to the root folder of repository from which we will be deploying code.
# If both Dockerfile and docker-compose.yaml are in the repository root folder, then we can leave the below values.
DOCKERFILE_PATH="$(Build.SourcesDirectory)/Dockerfile"
DOCKER_COMPOSE_PATH="docker-compose.yaml"

# Name of our Azure subscription
AZURE_SUBSCRIPTION_NAME="Azure subscription 1"

# devops organization and project names can be taken from url: dev.azure.com/<organization>/<project>
DEVOPS_ORGANIZATION = "your-organization"
DEVOPS_PROJECT = "your-project"

# personal access token from DevOps. It can be generated on the website
AZURE_DEVOPS_PAT = "your_token"
# Azure subscription ID
SUB_ID = "your_subscription"




# ============ Variables which values we can get from Terraform outputs. We need to run the Terraform code from the 'terraform' folder first. ============

# Below variables are related to the Service Principal with scope for our ACR and acrpush role which we created using Terraform.
# They will be used for creating a Service Connection in DevOps to ACR, pushing and pulling images from ACR.

# ID of the tenant of the Service Principal 
TENANT_ID = "37e1491b-96bc-4g73-8cf5-30efbch83250"
# Service Principal app ID and password
SP_ID = "bca1059f-0cf2-4734-a121-0b9c82h60478"
SP_PASSWORD = "xzA8Q~Yjk.INj14-jFMrPl1cdaJgnZFfiKkhhb.x"