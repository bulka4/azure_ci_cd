# ============ Variables for which we shouldn't be changing values. If we want to change them, then we might need to change other parts of code. ============

# Name of the Agent Pool which we will create.
POOL_NAME="data_engineering_apps"



# ============ Variables for which it is necessary to provide a correct values. ============

# personal access token from DevOps
AZURE_DEVOPS_PAT = "your_token"

# Name of the DevOps organization and project. They can be taken from URL: https://dev.azure.com/<organization>/<project>
ORGANIZATION="your_organization"
PROJECT="your_project"